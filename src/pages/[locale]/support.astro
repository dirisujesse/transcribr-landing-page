---
import { locales } from "../../paraglide/runtime.js";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
---

<Layout title="Help & Support -- Transcribr" locale={locale}>
  <section
    class="relative overflow-hidden bg-gradient-to-b from-primary-soft/50 to-white pt-28 pb-12 md:pt-32 md:pb-16"
  >
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center" data-animate>
        <p
          class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary"
        >
          Support
        </p>
        <h1
          class="text-4xl font-bold tracking-tight text-foreground md:text-5xl"
        >
          Help & Support
        </h1>
        <p
          class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground md:text-xl"
        >
          We're here to help. Browse the FAQ for quick answers or contact us
          directly if you need further assistance.
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-white pt-4 md:pt-8">
    <div class="container-page">
      <div class="mx-auto max-w-2xl">
        <div
          class="rounded-2xl border border-border bg-surface p-8"
          data-animate
        >
          <h2 class="text-2xl font-bold text-foreground">Contact us</h2>
          <p class="mt-3 text-muted-foreground">
            Send us a message and our team will respond as quickly as possible.
            For feature requests, use the feedback form instead.
          </p>
          <div class="mt-8 space-y-6">
            <div class="rounded-xl border border-border bg-white p-4">
              <p class="text-sm font-medium text-muted-foreground">Email</p>
              <a
                href="mailto:support@transcribr.org"
                class="mt-1 text-lg font-semibold text-primary hover:underline"
              >
                support@transcribr.org
              </a>
            </div>
            <div class="rounded-xl border border-border bg-white p-4">
              <p class="text-sm font-medium text-muted-foreground">
                Feedback & feature requests
              </p>
              <a
                href="https://app.transcribr.org/feedback"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 inline-flex items-center gap-2 text-primary hover:underline"
              >
                Open feedback form
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  ><path
                    d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"
                  ></path></svg
                >
              </a>
            </div>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/faq" class="btn-secondary">Browse FAQ</a>
            <a href="https://app.transcribr.org/auth" class="btn-primary"
              >Get started</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
