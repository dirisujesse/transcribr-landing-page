---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
import { localizeHref, locales as allLocales, baseLocale, getLocale, getTextDirection } from "../paraglide/runtime.js";
import { m } from "../paraglide/messages.js";

export interface Props {
  title: string;
  description?: string;
  locale: string;
}

const {
  title,
  description = m.layout_meta_description(),
  locale,
} = Astro.props;

const canonicalPath = Astro.url.pathname;
const canonicalURL = new URL(localizeHref(canonicalPath, { locale: baseLocale }), Astro.site);

const ogLocales: Record<string, string> = {
  en: "en_US",
  nl: "nl_NL",
  de: "de_DE",
  es: "es_ES",
  hr: "hr_HR",
  it: "it_IT",
  fr: "fr_FR",
};
---

<!doctype html>
<html lang={locale} dir={getTextDirection()}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" sizes="any" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,400..800;1,400..800&display=swap"
      rel="stylesheet"
    />
    <style is:inline>
      html,
      body {
        font-family: "Figtree", ui-sans-serif, system-ui, sans-serif;
      }
    </style>
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang -->
    {
      allLocales.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc}
          href={localizeHref(canonicalPath, { locale: loc })}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={localizeHref(canonicalPath, { locale: baseLocale })}
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://transcribr.org" />
    <meta property="og:image" content="https://transcribr.org/og-image.png" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="Transcribr" />
    <meta property="og:locale" content={ogLocales[locale] || "en_US"} />
    <meta name="theme-color" content="#5B4FE8" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://transcribr.org/og-image.png" />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:site" content="@transcribr" />
    <meta name="twitter:creator" content="@transcribr" />
    <meta name="twitter:domain" content="transcribr.org" />
    <meta name="twitter:url" content="https://transcribr.org" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer async></script>
    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Transcribr",
      "operatingSystem": "Web, iOS, Android",
      "applicationCategory": "BusinessApplication",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "description": description,
      "url": "https://transcribr.org"
    })} />

    <!-- Theme flash prevention -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem("theme");
        if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-primary-foreground"
    >
      {m.layout_skip_to_content()}
    </a>
    <Header locale={locale} />
    <div id="main-content">
      <slot />
    </div>
    <Footer />

    <script>
      const observerOptions = {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px",
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("animate-fade-up");
          }
        });
      }, observerOptions);

      document.addEventListener("DOMContentLoaded", () => {
        const elements = document.querySelectorAll("[data-animate]");
        elements.forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
