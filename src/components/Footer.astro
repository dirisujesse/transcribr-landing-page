---
import { m } from "../paraglide/messages.js";
import { localizeHref } from "../paraglide/runtime.js";

const year = new Date().getFullYear();
---

<footer class="bg-foreground py-16 text-background">
  <div class="container mx-auto px-4 lg:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        <div class="lg:col-span-1">
          <div class="mb-6">
            <a href={localizeHref("/", { locale: undefined })} class="inline-block brightness-0 invert">
              <img src="/logo.svg" alt="Transcribr" class="h-7 w-auto" />
            </a>
          </div>
          <p class="mb-6 text-sm text-background/70">
            {m.footer_tagline()}
          </p>
        </div>

        <div>
          <h3 class="mb-4 font-semibold text-background">{m.footer_product_heading()}</h3>
          <ul class="space-y-3 text-background/70">
            <li>
              <a href={localizeHref("/features", { locale: undefined })} class="transition-colors hover:text-background"
                >{m.footer_features()}</a
              >
            </li>
            <li>
              <a href="/#pricing" class="transition-colors hover:text-background"
                >{m.footer_pricing()}</a
              >
            </li>
            <li>
              <a
                href="https://app.transcribr.org/auth/signup"
                class="transition-colors hover:text-background">{m.footer_get_started()}</a
              >
            </li>
          </ul>
        </div>

        <div>
          <h3 class="mb-4 font-semibold text-background">{m.footer_company_heading()}</h3>
          <ul class="space-y-3 text-background/70">
            <li>
              <a href={localizeHref("/about", { locale: undefined })} class="transition-colors hover:text-background"
                >{m.footer_about()}</a
              >
            </li>
            <li>
              <a href={localizeHref("/faq", { locale: undefined })} class="transition-colors hover:text-background"
                >{m.footer_faq()}</a
              >
            </li>
            <li>
              <a href={localizeHref("/support", { locale: undefined })} class="transition-colors hover:text-background"
                >{m.footer_support()}</a
              >
            </li>
          </ul>
        </div>

        <div>
          <h3 class="mb-4 font-semibold text-background">{m.footer_legal_heading()}</h3>
          <ul class="space-y-3 text-background/70">
            <li>
              <a
                href={localizeHref("/privacy-policy", { locale: undefined })}
                class="transition-colors hover:text-background">{m.footer_privacy_policy()}</a
              >
            </li>
            <li>
              <a
                href={localizeHref("/terms-of-use", { locale: undefined })}
                class="transition-colors hover:text-background">{m.footer_terms_of_use()}</a
              >
            </li>
          </ul>
        </div>
      </div>

      <div
        class="flex flex-col items-center justify-between gap-4 border-t border-background/20 pt-8 md:flex-row"
      >
        <div class="text-sm text-background/70">
          {m.footer_copyright({ year })}
        </div>
        <div class="flex items-center gap-6 text-sm text-background/70">
          <a
            href={localizeHref("/privacy-policy", { locale: undefined })}
            class="transition-colors hover:text-background">{m.footer_privacy()}</a
          >
          <a href={localizeHref("/terms-of-use", { locale: undefined })} class="transition-colors hover:text-background"
            >{m.footer_terms()}</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
