---
const year = new Date().getFullYear();
---

<footer class="bg-foreground py-16 text-background">
  <div class="container mx-auto px-4 lg:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        <div class="lg:col-span-1">
          <div class="mb-6">
            <a href="/" class="inline-block brightness-0 invert">
              <img src="/logo.svg" alt="Transcribr" class="h-7 w-auto" />
            </a>
          </div>
          <p class="mb-6 text-sm text-background/70">
            Fast, accurate transcription with synchronized playback, speaker
            labels, and flexible export — built for professionals.
          </p>
        </div>

        <div>
          <h3 class="mb-4 font-semibold text-background">Product</h3>
          <ul class="space-y-3 text-background/70">
            <li>
              <a href="/features" class="transition-colors hover:text-background"
                >Features</a
              >
            </li>
            <li>
              <a href="/#pricing" class="transition-colors hover:text-background"
                >Pricing</a
              >
            </li>
            <li>
              <a
                href="https://app.transcribr.org/auth/signup"
                class="transition-colors hover:text-background">Get Started</a
              >
            </li>
          </ul>
        </div>

        <div>
          <h3 class="mb-4 font-semibold text-background">Company</h3>
          <ul class="space-y-3 text-background/70">
            <li>
              <a href="/about" class="transition-colors hover:text-background"
                >About</a
              >
            </li>
            <li>
              <a href="/faq" class="transition-colors hover:text-background"
                >FAQ</a
              >
            </li>
            <li>
              <a href="/support" class="transition-colors hover:text-background"
                >Support</a
              >
            </li>
          </ul>
        </div>

        <div>
          <h3 class="mb-4 font-semibold text-background">Legal</h3>
          <ul class="space-y-3 text-background/70">
            <li>
              <a
                href="/privacy-policy"
                class="transition-colors hover:text-background">Privacy Policy</a
              >
            </li>
            <li>
              <a
                href="/terms-of-use"
                class="transition-colors hover:text-background">Terms of Use</a
              >
            </li>
          </ul>
        </div>
      </div>

      <div
        class="flex flex-col items-center justify-between gap-4 border-t border-background/20 pt-8 md:flex-row"
      >
        <div class="text-sm text-background/70">
          © {year} Transcribr. All rights reserved.
        </div>
        <div class="flex items-center gap-6 text-sm text-background/70">
          <a
            href="/privacy-policy"
            class="transition-colors hover:text-background">Privacy</a
          >
          <a href="/terms-of-use" class="transition-colors hover:text-background"
            >Terms</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
