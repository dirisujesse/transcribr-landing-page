---
import AppStoreButtons from "./AppStoreButtons.astro";
import MockDashboard from "./mocks/MockDashboard.astro";
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-primary-soft/40 via-white to-surface pt-24 pb-16 md:pt-28 md:pb-24"
>
  <div class="container mx-auto px-4 lg:px-6">
    <div
      class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-16"
    >
      <!-- Copy -->
      <div class="text-center lg:text-left" data-animate>
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/15 bg-white px-3 py-1 text-xs font-medium text-primary shadow-sm"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-success"></span>
          AI transcription for web & mobile
        </div>

        <h1
          class="text-4xl font-bold leading-[1.1] tracking-tight text-foreground md:text-5xl lg:text-6xl"
        >
          Turn your audio into
          <span class="text-primary"> perfect text</span>
        </h1>

        <p
          class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-muted-foreground md:text-xl lg:mx-0"
        >
          Lightning-fast AI transcripts with speaker labels, synced playback,
          and exports — so you can edit and share in seconds.
        </p>

        <div class="mt-8 flex flex-col items-center gap-4 lg:items-start">
          <AppStoreButtons align="start" />
        </div>
      </div>

      <!-- Dashboard mock -->
      <div class="relative flex justify-center lg:justify-end" data-animate>
        <div
          class="pointer-events-none absolute -right-8 top-1/4 h-64 w-64 rounded-full bg-primary/15 blur-3xl"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute -left-4 bottom-8 h-40 w-40 rounded-full bg-primary/10 blur-2xl"
          aria-hidden="true"
        >
        </div>
        <MockDashboard variant="list" class="relative z-10" />
      </div>
    </div>
  </div>
</section>
