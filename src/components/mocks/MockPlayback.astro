---
import PhoneFrame from "./PhoneFrame.astro";
import { m } from "../../paraglide/messages.js";

/** Compact transcript player fragment */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<PhoneFrame class={className} statusBarTheme="dark">
  <div class="bg-white px-4 pb-6 pt-1">
    <div class="mb-3 flex items-center justify-between">
      <span class="flex h-8 w-8 items-center justify-center rounded-full bg-surface text-foreground" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
      </span>
      <span class="flex h-8 w-8 items-center justify-center rounded-full bg-surface text-muted-foreground" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M12 10v6M12 8h.01"></path>
        </svg>
      </span>
    </div>

    <h3 class="text-[17px] font-semibold text-foreground">{m.mock_playback_title()}</h3>
    <p class="mt-0.5 text-[11px] text-muted-foreground">
      {m.mock_playback_meta()}
    </p>

    <div class="mt-5 space-y-4">
      <div>
        <div class="mb-1.5 flex items-center justify-between">
          <span class="text-[11px] font-medium text-muted-foreground">00:00 – 01:15</span>
          <span class="text-[11px] font-semibold text-primary">{m.mock_playback_speaker1()} ▾</span>
        </div>
        <p class="text-[13px] leading-relaxed text-foreground">
          {m.mock_playback_jesse_text()}
        </p>
      </div>
      <div>
        <div class="mb-1.5 flex items-center justify-between">
          <span class="text-[11px] font-medium text-muted-foreground">01:16 – 03:45</span>
          <span class="text-[11px] font-semibold text-primary">{m.mock_playback_speaker2()} ▾</span>
        </div>
        <p class="text-[13px] leading-relaxed text-foreground">
          {m.mock_playback_speaker2_text()}
        </p>
      </div>
    </div>

    <!-- Player bar -->
    <div class="mt-8 border-t border-border pt-4">
      <div class="mb-3 flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-primary"></span>
        <div class="h-1 flex-1 overflow-hidden rounded-full bg-border">
          <div class="h-full w-[35%] rounded-full bg-primary"></div>
        </div>
      </div>
      <div class="mb-3 flex justify-between text-[10px] text-muted-foreground">
        <span>0:00</span>
        <span>10:00</span>
      </div>
      <div class="flex items-center justify-center gap-5">
        <span class="text-xs font-semibold text-muted-foreground">1X</span>
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-surface text-xs font-medium text-muted-foreground" aria-hidden="true">−10</span>
        <span class="flex h-14 w-14 items-center justify-center rounded-full bg-primary text-white shadow-lg shadow-primary/30" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"></path>
          </svg>
        </span>
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-surface text-xs font-medium text-muted-foreground" aria-hidden="true">+10</span>
        <span class="text-muted-foreground" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98"></path>
          </svg>
        </span>
      </div>
    </div>
  </div>
</PhoneFrame>
