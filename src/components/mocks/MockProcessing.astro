---
import { m } from "../../paraglide/messages.js";

/** Processing progress checklist fragment */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

const steps = [
  { label: m.mock_processing_step1(), done: true },
  { label: m.mock_processing_step2(), done: true },
  { label: m.mock_processing_step3(), done: true, active: true },
  { label: m.mock_processing_step4(), done: false },
  { label: m.mock_processing_step5(), done: false },
  { label: m.mock_processing_step6(), done: false },
  { label: m.mock_processing_step7(), done: false },
];
---

<div
  class:list={[
    "w-full max-w-sm rounded-2xl border border-border bg-white p-6 shadow-lg shadow-black/5",
    className,
  ]}
>
  <div class="mb-5 text-center">
    <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-primary-soft text-primary">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path d="M12 2a3 3 0 00-3 3v6a3 3 0 006 0V5a3 3 0 00-3-3z" />
        <path d="M19 10v1a7 7 0 01-14 0v-1" />
      </svg>
    </div>
    <h3 class="text-base font-semibold text-foreground">{m.mock_processing_heading()}</h3>
    <p class="mt-1 text-xs text-muted-foreground">
      {m.mock_processing_subtext()}
    </p>
  </div>

  <div class="mb-4">
    <div class="mb-1.5 flex justify-between text-[11px] font-medium">
      <span class="text-muted-foreground">{m.mock_processing_progress()}</span>
      <span class="text-primary">57%</span>
    </div>
    <div class="h-1.5 overflow-hidden rounded-full bg-border">
      <div class="h-full w-[57%] rounded-full bg-primary"></div>
    </div>
  </div>

  <ul class="space-y-2.5">
    {
      steps.map((s) => (
        <li class="flex items-center gap-2.5 text-[13px]">
          {s.done ? (
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary text-white">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
              </svg>
            </span>
          ) : (
            <span class="h-5 w-5 shrink-0 rounded-full border-2 border-border" />
          )}
          <span class:list={[s.done ? "text-foreground" : "text-muted-foreground"]}>
            {s.label}
          </span>
        </li>
      ))
    }
  </ul>
</div>
