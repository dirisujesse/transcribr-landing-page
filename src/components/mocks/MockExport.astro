---
import { m } from "../../paraglide/messages.js";

/** Export sheet fragment from Transcript Details design */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

const formats = [
  { label: m.mock_export_pdf(), free: true },
  { label: m.mock_export_txt(), free: true },
  { label: m.mock_export_srt(), free: true },
  { label: m.mock_export_vtt(), free: true },
  { label: m.mock_export_csv(), free: false },
];
---

<div
  class:list={[
    "w-full max-w-sm rounded-2xl border border-border bg-white p-5 shadow-lg shadow-black/5",
    className,
  ]}
>
  <div class="mb-4 flex items-center gap-2">
    <span class="text-muted-foreground" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </span>
    <h3 class="text-base font-semibold text-foreground">{m.mock_export_heading()}</h3>
  </div>

  <div class="mb-5 grid grid-cols-5 gap-2">
    {
      formats.map((f) => (
        <div class="flex flex-col items-center gap-1.5">
          <div class="flex h-12 w-full flex-col items-center justify-center rounded-xl border border-border bg-surface">
            <span class="text-[10px] font-bold uppercase tracking-wide text-primary">
              {f.free ? m.mock_export_free() : m.mock_export_pro()}
            </span>
            <span class="text-xs font-semibold text-foreground">{f.label}</span>
          </div>
        </div>
      ))
    }
  </div>

  <ul class="mb-5 space-y-3 border-t border-border pt-4">
    <li class="flex items-center justify-between text-sm text-foreground">
      <span class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground" aria-hidden="true">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
          <path d="M14 2v6h6" />
        </svg>
        {m.mock_export_toggle_text()}
      </span>
      <span class="relative h-5 w-9 rounded-full bg-primary">
        <span class="absolute right-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow"></span>
      </span>
    </li>
    <li class="flex items-center justify-between text-sm text-foreground">
      <span class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
        {m.mock_export_toggle_speakers()}
      </span>
      <span class="relative h-5 w-9 rounded-full bg-border">
        <span class="absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow"></span>
      </span>
    </li>
    <li class="flex items-center justify-between text-sm text-foreground">
      <span class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground" aria-hidden="true">
          <circle cx="12" cy="12" r="9" />
          <path d="M12 7v5l3 2" />
        </svg>
        {m.mock_export_toggle_timestamps()}
      </span>
      <span class="relative h-5 w-9 rounded-full bg-border">
        <span class="absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow"></span>
      </span>
    </li>
  </ul>

  <div class="rounded-full bg-primary py-3 text-center text-sm font-semibold text-white">
    {m.mock_export_button()}
  </div>
</div>
