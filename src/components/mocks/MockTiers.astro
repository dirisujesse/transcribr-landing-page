---
/** Compact Quick / Standard / Premium tier cards — marketing fragment */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

const tiers = [
  {
    name: "Quick",
    time: "~2 min",
    accuracy: "Basic",
    features: ["Basic transcription", "Standard timestamps"],
    highlight: false,
  },
  {
    name: "Standard",
    time: "~5 min",
    accuracy: "95–98%",
    features: ["Enhanced accuracy", "Speaker detection"],
    highlight: true,
  },
  {
    name: "Premium",
    time: "~10 min",
    accuracy: "98–99%",
    features: ["Highest accuracy", "Speaker identification"],
    highlight: false,
  },
];
---

<div
  class:list={[
    "w-full max-w-sm space-y-3 rounded-2xl border border-border bg-white p-4 shadow-lg shadow-black/5",
    className,
  ]}
>
  <p class="text-xs font-semibold text-muted-foreground">Select Transcription Type</p>
  {
    tiers.map((tier) => (
      <div
        class:list={[
          "rounded-xl border p-3.5 transition-colors",
          tier.highlight
            ? "border-primary bg-primary-soft/40 ring-1 ring-primary/20"
            : "border-border bg-white",
        ]}
      >
        <div class="flex items-center justify-between gap-2">
          <span class="text-sm font-semibold text-foreground">{tier.name}</span>
          {tier.highlight && (
            <span class="rounded-full bg-primary px-2 py-0.5 text-[10px] font-semibold text-white">
              Popular
            </span>
          )}
        </div>
        <div class="mt-2 flex gap-3 text-[11px] text-muted-foreground">
          <span>
            <span class="font-medium text-foreground/80">Time</span> {tier.time}
          </span>
          <span>
            <span class="font-medium text-foreground/80">Accuracy</span>{" "}
            {tier.accuracy}
          </span>
        </div>
        <div class="mt-2 flex flex-wrap gap-1.5">
          {tier.features.map((f) => (
            <span class="chip-neutral">{f}</span>
          ))}
        </div>
      </div>
    ))
  }
</div>
