---
import MockDashboard from "./mocks/MockDashboard.astro";
import MockTiers from "./mocks/MockTiers.astro";
import MockPlayback from "./mocks/MockPlayback.astro";
import MockExport from "./mocks/MockExport.astro";
import MockProcessing from "./mocks/MockProcessing.astro";
import CTABand from "./CTABand.astro";

const features = [
  {
    id: "tiers",
    eyebrow: "Transcription",
    title: "Speed or accuracy — you choose",
    description:
      "Pick Quick for drafts, Standard for everyday meetings, or Premium when every word and speaker label matters. Upload MP3, MP4, YouTube links, or other audio/video sources.",
    points: [
      "Quick, Standard, and Premium modes",
      "Works with audio files, video, and YouTube URLs",
      "Clear accuracy and time estimates per tier",
    ],
    visual: "tiers" as const,
    reverse: false,
  },
  {
    id: "processing",
    eyebrow: "Processing pipeline",
    title: "See every step as it happens",
    description:
      "From fetching your media to language detection, speech-to-text, speaker identification, and finalising — Transcribr shows live progress so you never wonder what's happening.",
    points: [
      "Live step-by-step progress checklist",
      "Detect errors early and retry if needed",
      "Track all jobs from your dashboard",
    ],
    visual: "processing" as const,
    reverse: true,
  },
  {
    id: "summarisation",
    eyebrow: "Summarisation & insights",
    title: "Turn raw transcripts into actionable notes",
    description:
      "Every completed transcript comes with a quick summary plus an executive summary that breaks down key topics with explanations, decisions and findings, and actionable takeaways — ideal for meetings, interviews, and court notes.",
    points: [
      "Quick summary for instant context",
      "Executive summary: overview, key topics, decisions, takeaways",
      "Identifies participants and follow-up items",
      "Save or share the summary as a PDF",
    ],
    visual: "speakers" as const,
    reverse: false,
  },
  {
    id: "playback",
    eyebrow: "Synced playback",
    title: "Never lose your place again",
    description:
      "Read along while audio plays. Current section highlights automatically. Jump to any timestamped block, scrub with ±10s controls, and adjust playback speed.",
    points: [
      "Section timestamps on every block",
      "Large play control with ±10s skip",
      "Current section highlights as audio plays",
      "Works with audio, video, and YouTube sources",
    ],
    visual: "playback" as const,
    reverse: true,
  },
  {
    id: "speakers",
    eyebrow: "Speakers & inline editing",
    title: "Know who said what — and fix it fast",
    description:
      "Automatic speaker labels keep multi-person meetings readable. Rename Speaker 1 and Speaker 2 to real names, edit text directly in-place, and bulk-update across all sections with one tap.",
    points: [
      "Automatic speaker detection with label assignment",
      "Rename speakers in one tap with modal",
      "Edit transcript text inline without leaving the view",
      "Bulk-update a speaker name across all sections",
    ],
    visual: "speakers" as const,
    reverse: false,
  },
  {
    id: "regeneration",
    eyebrow: "Regeneration",
    title: "Don't settle — regenerate",
    description:
      "Not happy with the result? Free users get one free regeneration. Pro users can regenerate unlimited times for the best possible transcript. No need to re-upload — just tap Regenerate.",
    points: [
      "Free users: one regeneration per transcript",
      "Pro users: unlimited regenerations",
      "No re-upload needed — regenerates from stored audio",
    ],
    visual: "tiers" as const,
    reverse: true,
  },
  {
    id: "export",
    eyebrow: "Export",
    title: "Ship transcripts in any format",
    description:
      "Download PDF, TXT, SRT, VTT, or CSV. Toggle plain text, speakers, and timestamps. SRT and VTT formats are built for subtitling — drop them straight into your video editor or media player.",
    points: [
      "PDF, TXT, SRT, VTT, CSV — five formats",
      "Free formats available on every plan",
      "SRT / VTT for video subtitling workflows",
      "Include speakers and timestamps as needed",
    ],
    visual: "export" as const,
    reverse: false,
  },
  {
    id: "workspace",
    eyebrow: "Workspace",
    title: "Your transcripts, organised",
    description:
      "A clean dashboard for everything you've transcribed — status chips for Transcribed, Processing, and Failed. Create new transcripts in one tap. Pro tools are ready when you need them.",
    points: [
      "Status at a glance: Transcribed, Processing, Failed",
      "Create new transcripts in one tap",
      "Web and mobile, same account and workflow",
      "Pro banner with Unlock Pro CTA",
    ],
    visual: "dashboard" as const,
    reverse: true,
  },
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-primary-soft/50 to-white pt-28 pb-16 md:pt-32 md:pb-20">
  <div class="container-page">
    <div class="mx-auto max-w-3xl text-center" data-animate>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
        Features
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-foreground md:text-5xl">
        Built for speed. Designed for accuracy.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground md:text-xl">
        Transcription with summarisation, insights, synced playback, inline
        editing, unlimited regeneration, and subtitle-ready exports — on web and
        mobile.
      </p>
    </div>
  </div>
</section>

{
  features.map((feature, i) => (
    <section
      id={feature.id}
      class:list={[i % 2 === 0 ? "section bg-white" : "section-muted"]}
    >
      <div class="container-page">
        <div
          class:list={[
            "mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-16",
            feature.reverse && "lg:[&>*:first-child]:order-2",
          ]}
        >
          <div data-animate>
            <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
              {feature.eyebrow}
            </p>
            <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
              {feature.title}
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
              {feature.description}
            </p>
            <ul class="mt-6 space-y-3">
              {feature.points.map((point) => (
                <li class="flex items-start gap-3 text-[15px] text-foreground">
                  <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary-soft text-primary">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                    </svg>
                  </span>
                  {point}
                </li>
              ))}
            </ul>
          </div>

          <div class="flex justify-center" data-animate>
            {feature.visual === "tiers" && <MockTiers />}
            {feature.visual === "processing" && <MockProcessing />}
            {feature.visual === "playback" && <MockPlayback />}
            {feature.visual === "export" && <MockExport />}
            {feature.visual === "dashboard" && (
              <MockDashboard variant="list" />
            )}
            {feature.visual === "speakers" && (
              <div class="w-full max-w-sm rounded-2xl border border-border bg-white p-5 shadow-lg shadow-black/5">
                <p class="mb-1 text-xs font-medium text-muted-foreground">
                  00:00 – 01:15
                </p>
                <div class="mb-2 flex items-center justify-between">
                  <span class="text-sm font-semibold text-primary">Jesse Makanaki ▾</span>
                  <span class="chip-processing">Renamed</span>
                </div>
                <p class="text-sm leading-relaxed text-foreground">
                  Good morning, everyone. Thanks for joining the stand-up. I've been reviewing the design sprint progress…
                </p>
                <div class="my-4 border-t border-border" />
                <p class="mb-1 text-xs font-medium text-muted-foreground">
                  01:16 – 03:45
                </p>
                <div class="mb-2 flex items-center justify-between">
                  <span class="text-sm font-semibold text-primary">Speaker 2 ▾</span>
                </div>
                <p class="text-sm leading-relaxed text-foreground">
                  I'm currently focused on the backend tasks related to the API integration…
                </p>
                <div class="mt-5 rounded-xl border border-border bg-surface p-4">
                  <p class="text-xs font-semibold text-foreground">Rename Speaker 1</p>
                  <div class="mt-2 rounded-lg border border-border bg-white px-3 py-2 text-sm text-muted-foreground">
                    Enter new name
                  </div>
                  <div class="mt-3 rounded-full bg-primary py-2.5 text-center text-sm font-semibold text-white">
                    Rename Speaker
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  ))
}

<section class="section bg-white">
  <div class="container-page">
    <div
      class="mx-auto max-w-3xl rounded-2xl border border-border bg-surface px-6 py-10 text-center md:px-12"
      data-animate
    >
      <h2 class="text-2xl font-bold text-foreground md:text-3xl">
        Same workflow on web, iOS, and beyond
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-muted-foreground">
        Start a transcript on your phone, finish editing on the web. Your
        workspace stays in sync so nothing gets stuck on one device.
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <span class="chip-neutral">Web app</span>
        <span class="chip-neutral">iOS</span>
        <span class="chip-neutral">Android coming soon</span>
      </div>
      <a href="/#pricing" class="btn-primary mt-8">
        View pricing
      </a>
    </div>
  </div>
</section>

<CTABand />
