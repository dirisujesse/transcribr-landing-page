---
import { m } from "../paraglide/messages.js";
import { localizeHref } from "../paraglide/runtime.js";
import MockDashboard from "./mocks/MockDashboard.astro";
import MockTiers from "./mocks/MockTiers.astro";
import MockPlayback from "./mocks/MockPlayback.astro";
import MockExport from "./mocks/MockExport.astro";
import MockProcessing from "./mocks/MockProcessing.astro";
import CTABand from "./CTABand.astro";

const features = [
  {
    id: "tiers",
    eyebrow: m.features_tiers_eyebrow(),
    title: m.features_tiers_title(),
    description: m.features_tiers_desc(),
    points: [
      m.features_tiers_point1(),
      m.features_tiers_point2(),
      m.features_tiers_point3(),
    ],
    visual: "tiers" as const,
    reverse: false,
  },
  {
    id: "processing",
    eyebrow: m.features_processing_eyebrow(),
    title: m.features_processing_title(),
    description: m.features_processing_desc(),
    points: [
      m.features_processing_point1(),
      m.features_processing_point2(),
      m.features_processing_point3(),
    ],
    visual: "processing" as const,
    reverse: true,
  },
  {
    id: "summarisation",
    eyebrow: m.features_summarisation_eyebrow(),
    title: m.features_summarisation_title(),
    description: m.features_summarisation_desc(),
    points: [
      m.features_summarisation_point1(),
      m.features_summarisation_point2(),
      m.features_summarisation_point3(),
      m.features_summarisation_point4(),
    ],
    visual: "speakers" as const,
    reverse: false,
  },
  {
    id: "playback",
    eyebrow: m.features_playback_eyebrow(),
    title: m.features_playback_title(),
    description: m.features_playback_desc(),
    points: [
      m.features_playback_point1(),
      m.features_playback_point2(),
      m.features_playback_point3(),
      m.features_playback_point4(),
    ],
    visual: "playback" as const,
    reverse: true,
  },
  {
    id: "speakers",
    eyebrow: m.features_speakers_eyebrow(),
    title: m.features_speakers_title(),
    description: m.features_speakers_desc(),
    points: [
      m.features_speakers_point1(),
      m.features_speakers_point2(),
      m.features_speakers_point3(),
      m.features_speakers_point4(),
    ],
    visual: "speakers" as const,
    reverse: false,
  },
  {
    id: "regeneration",
    eyebrow: m.features_regeneration_eyebrow(),
    title: m.features_regeneration_title(),
    description: m.features_regeneration_desc(),
    points: [
      m.features_regeneration_point1(),
      m.features_regeneration_point2(),
      m.features_regeneration_point3(),
    ],
    visual: "tiers" as const,
    reverse: true,
  },
  {
    id: "export",
    eyebrow: m.features_export_eyebrow(),
    title: m.features_export_title(),
    description: m.features_export_desc(),
    points: [
      m.features_export_point1(),
      m.features_export_point2(),
      m.features_export_point3(),
      m.features_export_point4(),
    ],
    visual: "export" as const,
    reverse: false,
  },
  {
    id: "workspace",
    eyebrow: m.features_workspace_eyebrow(),
    title: m.features_workspace_title(),
    description: m.features_workspace_desc(),
    points: [
      m.features_workspace_point1(),
      m.features_workspace_point2(),
      m.features_workspace_point3(),
      m.features_workspace_point4(),
    ],
    visual: "dashboard" as const,
    reverse: true,
  },
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-primary-soft/50 to-white pt-28 pb-16 md:pt-32 md:pb-20">
  <div class="container-page">
    <div class="mx-auto max-w-3xl text-center" data-animate>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
        {m.features_page_eyebrow()}
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-foreground md:text-5xl">
        {m.features_page_heading()}
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground md:text-xl">
        {m.features_page_subtext()}
      </p>
    </div>
  </div>
</section>

{
  features.map((feature, i) => (
    <section
      id={feature.id}
      class:list={[i % 2 === 0 ? "section bg-white" : "section-muted"]}
    >
      <div class="container-page">
        <div
          class:list={[
            "mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-16",
            feature.reverse && "lg:[&>*:first-child]:order-2",
          ]}
        >
          <div data-animate>
            <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
              {feature.eyebrow}
            </p>
            <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
              {feature.title}
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
              {feature.description}
            </p>
            <ul class="mt-6 space-y-3">
              {feature.points.map((point) => (
                <li class="flex items-start gap-3 text-[15px] text-foreground">
                  <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary-soft text-primary">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                    </svg>
                  </span>
                  {point}
                </li>
              ))}
            </ul>
          </div>

          <div class="flex justify-center" data-animate>
            {feature.visual === "tiers" && <MockTiers />}
            {feature.visual === "processing" && <MockProcessing />}
            {feature.visual === "playback" && <MockPlayback />}
            {feature.visual === "export" && <MockExport />}
            {feature.visual === "dashboard" && (
              <MockDashboard variant="list" />
            )}
            {feature.visual === "speakers" && (
              <div class="w-full max-w-sm rounded-2xl border border-border bg-white p-5 shadow-lg shadow-black/5">
                <p class="mb-1 text-xs font-medium text-muted-foreground">
                  {m.features_page_speakers_mock_time()}
                </p>
                <div class="mb-2 flex items-center justify-between">
                  <span class="text-sm font-semibold text-primary">{m.features_page_speakers_mock_speaker()}</span>
                  <span class="chip-processing">{m.features_page_speakers_mock_renamed()}</span>
                </div>
                <p class="text-sm leading-relaxed text-foreground">
                  {m.features_page_speakers_mock_jesse_text()}
                </p>
                <div class="my-4 border-t border-border" />
                <p class="mb-1 text-xs font-medium text-muted-foreground">
                  {m.features_page_speakers_mock_time2()}
                </p>
                <div class="mb-2 flex items-center justify-between">
                  <span class="text-sm font-semibold text-primary">{m.features_page_speakers_mock_speaker2()}</span>
                </div>
                <p class="text-sm leading-relaxed text-foreground">
                  {m.features_page_speakers_mock_speaker2_text()}
                </p>
                <div class="mt-5 rounded-xl border border-border bg-surface p-4">
                  <p class="text-xs font-semibold text-foreground">{m.features_page_speakers_mock_rename_title()}</p>
                  <div class="mt-2 rounded-lg border border-border bg-white px-3 py-2 text-sm text-muted-foreground">
                    {m.features_page_speakers_mock_rename_input()}
                  </div>
                  <div class="mt-3 rounded-full bg-primary py-2.5 text-center text-sm font-semibold text-white">
                    {m.features_page_speakers_mock_rename_button()}
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  ))
}

<section class="section bg-white">
  <div class="container-page">
    <div
      class="mx-auto max-w-3xl rounded-2xl border border-border bg-surface px-6 py-10 text-center md:px-12"
      data-animate
    >
      <h2 class="text-2xl font-bold text-foreground md:text-3xl">
        {m.features_cross_platform_heading()}
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-muted-foreground">
        {m.features_cross_platform_subtext()}
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <span class="chip-neutral">{m.features_cross_platform_web()}</span>
        <span class="chip-neutral">{m.features_cross_platform_ios()}</span>
        <span class="chip-neutral">{m.features_cross_platform_android()}</span>
      </div>
      <a href="/#pricing" class="btn-primary mt-8">
        {m.features_cross_platform_cta()}
      </a>
    </div>
  </div>
</section>

<CTABand />
