---
import { localizeHref, type Locale } from "../paraglide/runtime.js";

interface Props {
  class?: string;
  locale?: string;
}

const { class: className = "", locale } = Astro.props;
const href = locale
  ? localizeHref("/", { locale: locale as Locale })
  : localizeHref("/");
---

<a href={href} class:list={["inline-flex items-center", className]}>
  <img src="/logo.svg" alt="Transcribr" class="h-7 w-auto" />
</a>
