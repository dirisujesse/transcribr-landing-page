---
import Logo from "./Logo.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { localizeHref, type Locale } from "../paraglide/runtime.js";
import { m } from "../paraglide/messages.js";

export interface Props {
  locale: string;
}

const { locale } = Astro.props;
const currentLocale = locale as Locale;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const nav = [
  {
    href: localizeHref("/features", { locale: currentLocale }),
    label: m.nav_features(),
  },
  {
    href: localizeHref("/#pricing", { locale: currentLocale }),
    label: m.nav_pricing(),
  },
  {
    href: localizeHref("/about", { locale: currentLocale }),
    label: m.nav_about(),
  },
  { href: localizeHref("/faq", { locale: currentLocale }), label: m.nav_faq() },
];

function isActive(href: string) {
  if (href.includes("#")) return false;
  const path = href.replace(/\/$/, "") || "/";
  return pathname === path;
}

const openMenuLabel = m.nav_open_menu();
const closeMenuLabel = m.nav_close_menu();
---

<header
  class="fixed top-0 z-50 w-full border-b border-border/80 bg-background/80 backdrop-blur-md"
>
  <div class="container mx-auto px-4 lg:px-6">
    <div class="flex h-16 items-center justify-between gap-4">
      <Logo locale={locale} />

      <nav class="hidden items-center gap-7 md:flex" aria-label={m.nav_main()}>
        {
          nav.map((item) => (
            <a
              href={item.href}
              class={isActive(item.href) ? "nav-link-active" : "nav-link"}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-1.5 sm:gap-2">
        <div class="hidden sm:block">
          <LanguageSwitcher locale={locale} />
        </div>

        <a
          href="https://app.transcribr.org/auth"
          class="btn-ghost hidden h-9 sm:inline-flex"
        >
          {m.nav_sign_in()}
        </a>
        <a
          href="https://app.transcribr.org/auth"
          class="btn-primary h-9 px-4 text-sm sm:px-5"
        >
          {m.nav_get_started()}
        </a>

        <button
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full text-foreground transition-colors hover:bg-surface md:hidden"
          aria-label={m.nav_open_menu()}
          aria-expanded="false"
          aria-controls="mobile-nav"
          data-menu-toggle
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            data-menu-icon-open
          >
            <line x1="4" y1="7" x2="20" y2="7"></line>
            <line x1="4" y1="12" x2="20" y2="12"></line>
            <line x1="4" y1="17" x2="20" y2="17"></line>
          </svg>
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            class="hidden"
            data-menu-icon-close
          >
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="6" y1="18" x2="18" y2="6"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-nav"
    class="hidden border-t border-border bg-background md:hidden"
    data-mobile-nav
  >
    <nav
      class="container mx-auto flex flex-col gap-1 px-4 py-4"
      aria-label={m.nav_mobile()}
    >
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "rounded-xl px-4 py-3 text-sm font-medium transition-colors",
              isActive(item.href)
                ? "bg-primary-soft text-primary"
                : "text-foreground/80 hover:bg-surface hover:text-foreground",
            ]}
            data-menu-link
          >
            {item.label}
          </a>
        ))
      }

      <a
        href="https://app.transcribr.org/auth"
        class="rounded-xl px-4 py-3 text-sm font-medium text-foreground/80 hover:bg-surface hover:text-foreground sm:hidden"
        data-menu-link
      >
        {m.nav_sign_in()}
      </a>

      <div
        class="mt-3 flex w-full items-center rounded-xl border border-border bg-surface p-1 sm:hidden"
      >
        <LanguageSwitcher locale={locale} align="start" fullWidth />
      </div>
    </nav>
  </div>
</header>

<script define:vars={{ openMenuLabel, closeMenuLabel }}>
  const toggle = document.querySelector("[data-menu-toggle]");
  const panel = document.querySelector("[data-mobile-nav]");
  const iconOpen = document.querySelector("[data-menu-icon-open]");
  const iconClose = document.querySelector("[data-menu-icon-close]");
  const links = document.querySelectorAll("[data-menu-link]");

  function setOpen(open) {
    if (!toggle || !panel || !iconOpen || !iconClose) return;
    panel.classList.toggle("hidden", !open);
    iconOpen.classList.toggle("hidden", open);
    iconClose.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? closeMenuLabel : openMenuLabel);
  }

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    setOpen(!open);
  });

  links.forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });
</script>
