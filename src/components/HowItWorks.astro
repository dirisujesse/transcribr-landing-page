---
const steps = [
  {
    step: "01",
    title: "Upload or paste a link",
    description:
      "Drop an audio or video file, or paste a URL. MP3, MP4, WAV, and more — up to an hour per file.",
    icon: "upload",
  },
  {
    step: "02",
    title: "Transcription in minutes",
    description:
      "Choose Quick, Standard, or Premium. We detect language, chunk audio, identify speakers, and finalize your transcript.",
    icon: "process",
  },
  {
    step: "03",
    title: "Edit, play, and export",
    description:
      "Tap any section to jump in the audio, rename speakers, polish the text, then export PDF, TXT, SRT, VTT, or CSV.",
    icon: "export",
  },
];
---

<section class="section bg-white" id="how-it-works">
  <div class="container-page">
    <div class="mx-auto mb-14 max-w-2xl text-center" data-animate>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
        How it works
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        From audio to finished transcript in three steps
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Built for meetings, interviews, court notes, and content — without the
        busywork.
      </p>
    </div>

    <ol class="grid gap-6 md:grid-cols-3 md:gap-8">
      {
        steps.map((item) => (
          <li
            class="relative rounded-2xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md md:p-8"
            data-animate
          >
            <div class="mb-5 flex items-center justify-between">
              <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary-soft text-primary">
                {item.icon === "upload" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <path d="M12 16V4M12 4l-4 4M12 4l4 4" />
                    <path d="M4 14v4a2 2 0 002 2h12a2 2 0 002-2v-4" />
                  </svg>
                )}
                {item.icon === "process" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <path d="M12 2a3 3 0 00-3 3v6a3 3 0 006 0V5a3 3 0 00-3-3z" />
                    <path d="M19 10v1a7 7 0 01-14 0v-1" />
                    <path d="M12 18v3" />
                  </svg>
                )}
                {item.icon === "export" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                    <path d="M14 2v6h6M8 13h8M8 17h5" />
                  </svg>
                )}
              </span>
              <span class="text-sm font-bold text-primary/40">{item.step}</span>
            </div>
            <h3 class="text-xl font-semibold text-foreground">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground md:text-[15px]">
              {item.description}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
