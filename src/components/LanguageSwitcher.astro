---
import {
  locales as availableLanguageTags,
  baseLocale,
  localizeHref,
} from "../paraglide/runtime.js";
import { m } from "../paraglide/messages.js";

interface Props {
  locale: string;
  /** Dropdown alignment relative to the trigger */
  align?: "start" | "end";
  /** Stretch the control to full width (mobile capsule) */
  fullWidth?: boolean;
}

const { locale, align = "end", fullWidth = false } = Astro.props;

const currentPath = Astro.url.pathname;
const currentLocale = locale || baseLocale;

const localeNames: Record<string, string> = {
  en: "English",
  nl: "Nederlands",
  de: "Deutsch",
  es: "Español",
  hr: "Hrvatski",
  it: "Italiano",
  fr: "Français",
};

const options = availableLanguageTags.map((tag) => ({
  tag,
  label: localeNames[tag] ?? tag,
  href: localizeHref(currentPath, { locale: tag }),
  active: tag === currentLocale,
}));
---

<div
  class:list={["relative", fullWidth && "w-full"]}
  data-lang-root
>
  <button
    type="button"
    class:list={[
      "inline-flex h-9 items-center gap-1.5 rounded-full px-2.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-surface hover:text-foreground",
      fullWidth && "w-full justify-start rounded-lg hover:bg-transparent",
    ]}
    aria-label={m.language_switcher_label()}
    aria-haspopup="listbox"
    aria-expanded="false"
    data-lang-trigger
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18"></path>
    </svg>
    <span class="uppercase tracking-wide">{currentLocale}</span>
  </button>

  <div
    class:list={[
      "absolute top-full z-50 mt-2 hidden w-48 overflow-hidden rounded-xl border border-border bg-card p-1 shadow-lg shadow-black/5",
      align === "start" ? "left-0" : "right-0",
      fullWidth && "w-full",
    ]}
    role="listbox"
    aria-label={m.language_switcher_label()}
    data-lang-menu
  >
    {
      options.map((opt) => (
        <a
          href={opt.href}
          role="option"
          aria-selected={opt.active}
          class:list={[
            "flex w-full items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors",
            opt.active
              ? "bg-primary-soft font-medium text-primary"
              : "text-foreground hover:bg-surface",
          ]}
          data-lang-option
        >
          <span>{opt.label}</span>
          {opt.active && (
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12l5 5L20 7" />
            </svg>
          )}
        </a>
      ))
    }
  </div>
</div>

<script>
  function initLanguageSwitcher(root: Element) {
    const trigger = root.querySelector("[data-lang-trigger]");
    const menu = root.querySelector("[data-lang-menu]");
    if (!(trigger instanceof HTMLElement) || !(menu instanceof HTMLElement)) return;

    function setOpen(open: boolean) {
      menu.classList.toggle("hidden", !open);
      trigger.setAttribute("aria-expanded", String(open));
    }

    function toggleOpen(e: Event) {
      const target = e.target as Node | null;
      if (target && menu.contains(target)) return;
      e.preventDefault();
      e.stopPropagation();
      const open = trigger.getAttribute("aria-expanded") === "true";
      setOpen(!open);
    }

    root.addEventListener("click", toggleOpen);

    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) setOpen(false);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
  }

  document.querySelectorAll("[data-lang-root]").forEach(initLanguageSwitcher);
</script>
