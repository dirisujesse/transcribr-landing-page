---
import { m } from "../paraglide/messages.js";
import { localizeHref } from "../paraglide/runtime.js";

const highlights = [
  {
    title: m.features_teaser_1_title(),
    description: m.features_teaser_1_desc(),
  },
  {
    title: m.features_teaser_2_title(),
    description: m.features_teaser_2_desc(),
  },
  {
    title: m.features_teaser_3_title(),
    description: m.features_teaser_3_desc(),
  },
  {
    title: m.features_teaser_4_title(),
    description: m.features_teaser_4_desc(),
  },
  {
    title: m.features_teaser_5_title(),
    description: m.features_teaser_5_desc(),
  },
  {
    title: m.features_teaser_6_title(),
    description: m.features_teaser_6_desc(),
  },
  {
    title: m.features_teaser_7_title(),
    description: m.features_teaser_7_desc(),
  },
  {
    title: m.features_teaser_8_title(),
    description: m.features_teaser_8_desc(),
  },
];
---

<section class="section-muted" id="features-teaser">
  <div class="container-page">
    <div
      class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-8 md:flex-row md:items-end"
      data-animate
    >
      <div class="max-w-xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
          {m.features_label()}
        </p>
        <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
          {m.features_heading()}
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
          {m.features_subtext()}
        </p>
      </div>
      <a href={localizeHref("/features", { locale: undefined })} class="btn-primary shrink-0">
        {m.features_explore_all()}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        highlights.map((item) => (
          <div
            class="rounded-2xl border border-border bg-white p-5 shadow-sm"
            data-animate
          >
            <div class="mb-3 h-1 w-8 rounded-full bg-primary" />
            <h3 class="font-semibold text-foreground">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
