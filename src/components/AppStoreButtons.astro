---
import { m } from "../paraglide/messages.js";

interface Props {
  align?: "center" | "start";
  theme?: "default" | "on-primary";
  showNote?: boolean;
}

const { align = "center", theme = "default", showNote = true } = Astro.props;

const onPrimary = theme === "on-primary";
---

<div>
  <div
    class:list={[
      "flex flex-col gap-3 sm:flex-row sm:items-center",
      align === "center"
        ? "items-center justify-center"
        : "items-stretch sm:justify-start",
    ]}
  >
    <a
      href="https://apps.apple.com/ng/app/transcribr-mobile/id6753605154"
      target="_blank"
      rel="noopener noreferrer"
      class:list={[
        "inline-flex items-center rounded-full px-5 py-3 transition-colors",
        onPrimary
          ? "bg-white text-foreground hover:bg-white/90"
          : "bg-foreground text-white hover:bg-foreground/90",
      ]}
      aria-label={m.store_aria_app_store()}
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="mr-3 shrink-0"
        aria-hidden="true"
      >
        <path
          d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
        ></path>
      </svg>
      <div class="text-left">
        <div class="text-[10px] leading-none opacity-70">
          {m.store_download_label()}
        </div>
        <div class="text-sm font-semibold leading-tight">
          {m.store_app_store()}
        </div>
      </div>
    </a>

    <a
      href="https://app.transcribr.org/auth"
      target="_blank"
      rel="noopener noreferrer"
      class:list={[
        "inline-flex items-center rounded-full px-5 py-3 transition-colors",
        onPrimary
          ? "bg-white/15 text-white ring-1 ring-white/30 hover:bg-white/25"
          : "bg-primary text-primary-foreground hover:bg-primary-dark",
      ]}
      aria-label={m.store_aria_web_app()}
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="mr-3 shrink-0"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18"></path>
      </svg>
      <div class="text-left">
        <div class="text-[10px] leading-none opacity-70">
          {m.store_try_label()}
        </div>
        <div class="text-sm font-semibold leading-tight">
          {m.store_browser()}
        </div>
      </div>
    </a>
  </div>

  {
    showNote && (
      <p
        class:list={[
          "mt-4 text-sm",
          onPrimary
            ? "text-center text-white/70"
            : align === "center"
              ? "text-center text-muted-foreground"
              : "text-center text-muted-foreground lg:text-left",
        ]}
      >
        {m.store_free_note()}
      </p>
    )
  }
</div>
