                  fill="currentColor"
                  class="text-white"
                >
                  <path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7L19.59 5.59Z"
                  ></path>
                </svg>
                <span>Speaker identification</span>
              </div>
              <div class="flex items-center space-x-3">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-white"
                >
                  <path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7L19.59 5.59Z"
                  ></path>
                </svg>
                <span>Synchronized audio playback</span>
              </div>
              <div class="flex items-center space-x-3">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-white"
                >
                  <path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7L19.59 5.59Z"
                  ></path>
                </svg>
                <span>Time-stamped sections</span>
              </div>
              <div class="flex items-center space-x-3">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-white"
                >
                  <path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7L19.59 5.59Z"
                  ></path>
                </svg>
