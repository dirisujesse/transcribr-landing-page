---
import { m } from "../paraglide/messages.js";

const appUrl = "https://app.transcribr.org/auth/signup";

const check = `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7L19.59 5.59Z"/></svg>`;
const cross = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>`;

const plans = [
  {
    name: m.pricing_plan_free_name(),
    price: "$0",
    period: m.pricing_plan_premium_period(),
    blurb: m.pricing_plan_free_blurb(),
    featured: false,
    cta: m.pricing_plan_free_cta(),
    features: [
      { text: m.pricing_plan_free_feat1(), included: true },
      { text: m.pricing_plan_free_feat2(), included: true },
      { text: m.pricing_plan_free_feat3(), included: true },
      { text: m.pricing_plan_free_feat4(), included: true },
      { text: m.pricing_plan_free_feat5(), included: true },
      { text: m.pricing_plan_free_feat6(), included: true },
      { text: m.pricing_plan_free_feat7(), included: false },
    ],
  },
  {
    name: m.pricing_plan_weekly_name(),
    price: m.pricing_plan_weekly_price(),
    period: m.pricing_plan_weekly_period(),
    blurb: m.pricing_plan_weekly_blurb(),
    featured: false,
    cta: m.pricing_plan_weekly_cta(),
    features: [
      { text: m.pricing_plan_weekly_feat1(), included: true },
      { text: m.pricing_plan_weekly_feat2(), included: true },
      { text: m.pricing_plan_weekly_feat3(), included: true },
      { text: m.pricing_plan_weekly_feat4(), included: true },
      { text: m.pricing_plan_weekly_feat5(), included: true },
      { text: m.pricing_plan_weekly_feat6(), included: true },
    ],
  },
  {
    name: m.pricing_plan_premium_name(),
    price: m.pricing_plan_premium_price(),
    period: m.pricing_plan_premium_period(),
    blurb: m.pricing_plan_premium_blurb(),
    featured: true,
    badge: m.pricing_plan_premium_badge(),
    cta: m.pricing_plan_premium_cta(),
    features: [
      { text: m.pricing_plan_premium_feat1(), included: true },
      { text: m.pricing_plan_premium_feat2(), included: true },
      { text: m.pricing_plan_premium_feat3(), included: true },
      { text: m.pricing_plan_premium_feat4(), included: true },
      { text: m.pricing_plan_premium_feat5(), included: true },
      { text: m.pricing_plan_premium_feat6(), included: true },
      { text: m.pricing_plan_premium_feat7(), included: true },
    ],
  },
];
---

<section id="pricing" class="section bg-surface">
  <div class="container-page">
    <div class="mx-auto mb-14 max-w-2xl text-center" data-animate>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
        {m.pricing_label()}
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        {m.pricing_heading()}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        {m.pricing_subtext()}
      </p>
    </div>

    <div class="mx-auto grid max-w-5xl gap-6 md:grid-cols-3 md:items-stretch">
      {
        plans.map((plan) => (
          <div
            class:list={[
              "relative flex h-full flex-col rounded-2xl border p-6 md:p-8",
              plan.featured
                ? "border-primary bg-primary text-primary-foreground shadow-xl shadow-primary/20 md:scale-[1.02] md:z-10"
                : "border-border bg-white shadow-sm",
            ]}
            data-animate
          >
            {plan.badge && (
              <span class="absolute right-4 top-4 rounded-full bg-white px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-primary">
                {plan.badge}
              </span>
            )}

            <div class="mb-6">
              <h3
                class:list={[
                  "text-xl font-bold",
                  plan.featured ? "text-white" : "text-foreground",
                ]}
              >
                {plan.name}
              </h3>
              <div class="mt-3 flex items-baseline gap-1">
                <span class="text-4xl font-bold tracking-tight">{plan.price}</span>
                <span
                  class:list={[
                    "text-sm font-medium",
                    plan.featured ? "text-white/70" : "text-muted-foreground",
                  ]}
                >
                  {plan.period}
                </span>
              </div>
              <p
                class:list={[
                  "mt-2 text-sm",
                  plan.featured ? "text-white/75" : "text-muted-foreground",
                ]}
              >
                {plan.blurb}
              </p>
            </div>

            <ul class="mb-8 flex-1 space-y-3">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm">
                  <span
                    class:list={[
                      "mt-0.5 shrink-0",
                      f.included
                        ? plan.featured
                          ? "text-white"
                          : "text-primary"
                        : plan.featured
                          ? "text-white/40"
                          : "text-muted-foreground",
                    ]}
                    set:html={f.included ? check : cross}
                  />
                  <span
                    class:list={[
                      !f.included &&
                        (plan.featured ? "text-white/50" : "text-muted-foreground"),
                    ]}
                  >
                    {f.text}
                  </span>
                </li>
              ))}
            </ul>

            <a
              href={appUrl}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "inline-flex w-full items-center justify-center rounded-full px-5 py-3 text-sm font-semibold transition-colors",
                plan.featured
                  ? "bg-white text-primary hover:bg-white/90"
                  : plan.name === m.pricing_plan_weekly_name()
                    ? "bg-primary-soft text-primary hover:bg-primary/15"
                    : "bg-surface text-foreground hover:bg-border/60",
              ]}
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>

    <div
      class="mx-auto mt-12 max-w-3xl rounded-2xl border border-border bg-white p-8 text-center shadow-sm"
      data-animate
    >
      <div
        class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary-soft text-primary"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"></path>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-foreground md:text-2xl">
        {m.pricing_human_heading()}
      </h3>
      <p class="mx-auto mt-3 max-w-xl text-muted-foreground">
        {m.pricing_human_subtext()}
      </p>
    </div>
  </div>
</section>
