---
import { m } from "../paraglide/messages.js";
import AppStoreButtons from "./AppStoreButtons.astro";
---

<section class="section relative overflow-hidden bg-primary">
  <div
    class="pointer-events-none absolute -left-20 top-0 h-64 w-64 rounded-full bg-white/10 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -right-16 bottom-0 h-72 w-72 rounded-full bg-white/10 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="container-page relative z-10">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
        {m.cta_heading()}
      </h2>
      <p class="mt-4 text-lg text-white/80">
        {m.cta_subtext()}
      </p>
      <div class="mt-8 flex justify-center">
        <AppStoreButtons theme="on-primary" />
      </div>
    </div>
  </div>
</section>
